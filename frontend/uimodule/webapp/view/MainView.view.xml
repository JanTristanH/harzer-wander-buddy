<mvc:View controllerName="hwb.harzerWanderBuddy.controller.MainView"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m"
    xmlns:vbm="sap.ui.vbm"
    xmlns:gmaps="openui5.googlemaps">
    <Page id="page" title="{i18n>title}">
        <Label text="Enable Hyphenation" />
        <VBox>
            <gmaps:Map id="gmap" ready="onMapReady" class="googleMap" fitToMarkers="true" markers="{/Stampboxes}" height="500px" zoom="12" lat="53.5704400" lng="9.964820000">

                <gmaps:Marker lat="{latitude}" lng="{longitude}" info="{number} - {name}"></gmaps:Marker>
            </gmaps:Map>
        </VBox>
        <content />
    </Page>
</mvc:View>
