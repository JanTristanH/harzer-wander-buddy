{
  "welcomeFile": "uimodule/index.html",
  "authenticationMethod": "none",
  "logout": {
    "logoutEndpoint": "/do/logout"
  },
  "routes": [
    {
      "source": "^/uimodule/(.*)$",
      "target": "$1",
      "authenticationType": "none",
      "localDir": "../uimodule/webapp"
    },
    {
      "source": "^/v2/(.*)$",
      "target": "/v2/$1",
      "destination": "api",
      "authenticationType": "none"
    },
    {
      "source": "^/ar/openui5-googlemaps/(.*)$",
      "target": "/jasper07/openui5-googlemaps/master/src/$1",
      "destination": "github",
      "authenticationType": "none"
    }
  ]
}
